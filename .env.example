# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub Token (for GitHub integrations)
GITHUB_TOKEN=ghp-your-github-token-here

# Hugging Face Token
HF_TOKEN=hf_your-token-here

# Docker build target: cpu | gpu
DEVICE=cpu

# Neo4j Database Configuration (local dev — docker compose uses bolt://neo4j-api:7687 internally)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB Configuration (local dev — docker compose maps 8091→8000 internally)
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_PORT=8091

# PostgreSQL Configuration
POSTGRES_PASSWORD=graphkb_password
DATABASE_URL=postgresql+asyncpg://graphkb:graphkb_password@localhost:5432/graphkb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# LLM Configuration
OPENAI_MODEL=gpt-5.2
LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=mistral

# Embedding Configuration
EMBEDDING_MODEL=jinaai/jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024
# EMBEDDING_DEVICE=       # auto-detect (cuda > mps > cpu). Set explicitly to force: cuda, mps, cpu
# EMBEDDING_SIMILARITY=cosine

# Chunking
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Storage Paths
REPO_STORAGE_PATH=/data/repos
# SPEC_STORAGE_PATH=/data/spec_artifacts
# MAX_CONTEXT_TOKENS=6000

# Graph Traversal
MAX_DEPTH=25

# Agent Configuration
# SHOW_AGENT_TOOL_CALLS=true
DEEP_AGENT_MAX_ITERATIONS=50

# LangGraph v3
LANGGRAPH_V3_ENABLED=true
LANGGRAPH_CHECKPOINTER_TYPE=postgres
# LANGGRAPH_POSTGRES_URI=

# LLM Recording — record | replay | off
LLM_RECORDING_MODE=off
# LLM_RECORDING_DIR=/llm-recordings
# LLM_MOCK_DIR=/llm-recordings

# S3 / MinIO Storage
# S3_ACCESS_KEY / S3_SECRET_KEY: used by docker-compose to configure MinIO root credentials
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: used by the app (blob_storage.py) — must match MinIO credentials
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9010
S3_BUCKET=documents
AWS_REGION=us-east-1

# Dashboard (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Debug
# DEBUG_LOG_TO_FILE=false

# CORS
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
